# Tachikoma Configuration Example
# Copy this file to .env and update with your actual values

# API Configuration
TACHIKOMA_GROQ_API_KEY=your_groq_api_key_here
TACHIKOMA_MODEL_NAME=llama-3.1-70b-versatile

# System Configuration
TACHIKOMA_MAX_AGENTS=10
TACHIKOMA_CONVERSATION_TIMEOUT=300
TACHIKOMA_RESOURCE_UPDATE_INTERVAL=30

# UI Configuration
TACHIKOMA_UI_TITLE=Tachikoma Multi-Agent AI System
TACHIKOMA_UI_THEME=default
TACHIKOMA_ENABLE_VISUALIZATION=true

# Logging Configuration
TACHIKOMA_LOG_LEVEL=INFO
TACHIKOMA_LOG_FILE=tachikoma.log

# Performance Configuration
TACHIKOMA_ENABLE_CACHING=true
TACHIKOMA_CACHE_TTL=3600
TACHIKOMA_MAX_CONCURRENT_AGENTS=5

# Export Configuration
TACHIKOMA_EXPORT_FORMAT=both
TACHIKOMA_EXPORT_DIRECTORY=./exports
